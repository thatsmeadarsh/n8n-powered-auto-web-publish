# Copy this file to config.env and update the values for your environment.
# config.env is gitignored and will not be committed.

# --- Hugo Project ---
HUGO_DIR="/path/to/your/hugo-project"
POSTS_DIR="${HUGO_DIR}/content/posts"

# --- n8n Webhook ---
WEBHOOK_URL="http://localhost:5678/webhook/publish-post"

# --- Logging ---
LOG_DIR="/path/to/n8n-powered-auto-web-publish/logs"

# --- Site URL (used to construct post links) ---
SITE_BASE_URL="https://yourusername.github.io"

# --- Hugging Face (AI-generated LinkedIn post) ---
HF_API_TOKEN="hf_your_token_here"
HF_MODEL_ID="Meta-Llama-3.1-8B-Instruct"

# --- LinkedIn ---
# LinkedIn OAuth2 credentials are configured inside n8n.
# See docs/linkedin-oauth-setup.md for instructions.
